generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversion {
  id        String   @id @default(cuid())
  userId    String
  platform  String   // "youtube" | "instagram"
  sourceUrl String
  title     String?
  preview   String?  // 첫 100자
  resultJson Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model UserCredit {
  id        String   @id @default(cuid())
  userId    String   @unique
  credits   Int      @default(1)  // 무료 1회
  plan      String   @default("free") // "free" | "starter" | "pro"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int      // +충전, -사용
  reason    String   // "signup" | "purchase" | "convert"
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}
